<%= render "layouts/signed_out_header" %>

<%= @debug.presence %>

<div class="flex flex-row justify-center">
  <div class="p-5 bg-gray-300 rounded-sm shadow-md">
    <h2 class="pb-2 text-lg">Guest Login:</h2>
    <%= simple_form_for :session, url: guest_group_auth_path(@guest_group), local: true, method: :post do |f| %>
      <div class="form-inputs">
        <%= f.input :passphrase, autofocus: true, autocomplete: "current-password" %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Log in" %>
      </div>
    <% end %>
  </div>
</div>

